# ============================================
# API 密钥配置
# ============================================

# LLM API 密钥（必填）
OPENAI_API_KEY=your_openai_api_key_here

# Embedding API 密钥
EMBEDDING_API_KEY=your_embedding_api_key_here

# Rerank API 密钥
REANK_API_KEY=your_rerank_api_key_here

# OCR API 密钥（PaddleOCR）
PADDLEOCR_API_KEY=your_paddleocr_api_key_here

# ============================================
# 数据库配置
# ============================================

# Milvus 向量数据库主机
MILVUS_HOST=localhost

# SQLite 数据库认证
SQLITE_USERNAME=root
SQLITE_PASSWORD=your_sqlite_password_here
